# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in real values
# This file is safe to commit; .env is not.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional — defaults work for the Docker setup ────────────────────────────

# Paths inside the backend container (change only if you move files)
MODEL_PATH=/app/models/beer_multioutput_classifier.pkl
ENCODERS_PATH=/app/models/label_encoders.pkl
BEER_XLSX_PATH=/app/data/Beer_data (1).xlsx

# Server
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=info

# CORS — add your production frontend URL here when deploying to AWS
# Example: ["https://beer.your-domain.com","http://localhost"]
ALLOWED_ORIGINS=["http://localhost","http://localhost:80","http://localhost:8002"]
